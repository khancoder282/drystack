{
  "name": "@drystack/core",
  "version": "0.5.50",
  "description": "Core engine for drystack, a git-backed CMS for Astro inspired by Keystatic.",
  "license": "MIT",
  "homepage": "https://github.com/khancoder282/drystack",
  "repository": {
    "type": "git",
    "url": "https://github.com/khancoder282/drystack/",
    "directory": "packages/drystack"
  },
  "type": "module",
  "keywords": [
    "drystack",
    "cms",
    "keystatic",
    "astro",
    "cloudflare",
    "git-cms",
    "headless-cms",
    "content-management"
  ],
  "files": ["dist"],
  "exports": {
    ".": "./dist/index.js",
    "./ui": "./dist/ui.js",
    "./api/utils": "./dist/api/utils.js",
    "./api/generic": "./dist/api/generic.js",
    "./renderer": "./dist/renderer.js",
    "./path-utils": "./dist/app/path-utils.js",
    "./redirects": "./dist/app/redirects.js",
    "./edit-sync": "./dist/app/edit-sync.js",
    "./required-files": "./dist/app/required-files.js",
    "./build-status": "./dist/app/build-status.js",
    "./build-status-protocol": "./dist/app/build-status-protocol.js",
    "./brand-store": "./dist/app/brand-store.js",
    "./brand-label": "./dist/app/brand-label.js",
    "./deploy-merge": "./dist/app/deploy/merge3.js",
    "./deploy-merge-base": "./dist/app/deploy/merge-base.js",
    "./deploy-progress-toast": "./dist/app/DeployProgressToast.js",
    "./yaml": "./dist/yaml.js",
    "./reader": "./dist/reader/index.js",
    "./reader/github": "./dist/reader/github.js",
    "./content-components": "./dist/content-components.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "setup": "tsx scripts/l10n.ts && tsx scripts/build-prism.ts",
    "build": "bun run setup && node scripts/build.mjs",
    "dev": "astro dev"
  },
  "dependencies": {
    "@babel/runtime": "^7.18.3",
    "@braintree/sanitize-url": "^6.0.2",
    "@emotion/weak-memoize": "^0.3.0",
    "@floating-ui/react": "^0.24.0",
    "@internationalized/string": "^3.2.6",
    "@keystar/ui": "^0.7.21",
    "@markdoc/markdoc": "^0.4.0",
    "@react-aria/focus": "^3.20.2",
    "@react-aria/i18n": "^3.12.8",
    "@react-aria/interactions": "^3.25.0",
    "@react-aria/label": "^3.7.17",
    "@react-aria/overlays": "^3.27.0",
    "@react-aria/selection": "^3.24.0",
    "@react-aria/utils": "^3.28.2",
    "@react-aria/visually-hidden": "^3.8.22",
    "@react-stately/collections": "^3.12.3",
    "@react-stately/list": "^3.12.1",
    "@react-stately/overlays": "^3.6.15",
    "@react-stately/utils": "^3.10.6",
    "@react-types/shared": "^3.29.0",
    "@sindresorhus/slugify": "^1.1.2",
    "@ts-gql/tag": "^0.7.3",
    "@types/react": "^19.0.8",
    "@urql/core": "^5.0.4",
    "@urql/exchange-auth": "^2.2.0",
    "@urql/exchange-graphcache": "^7.1.2",
    "@urql/exchange-persisted": "^4.3.0",
    "cookie": "^1.0.0",
    "emery": "^1.4.1",
    "escape-string-regexp": "^4.0.0",
    "fast-deep-equal": "^3.1.3",
    "graphql": "^16.6.0",
    "idb-keyval": "^6.2.1",
    "ignore": "^5.2.4",
    "is-hotkey": "^0.2.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^10.2.0",
    "match-sorter": "^6.3.1",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-gfm-autolink-literal": "^2.0.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.0",
    "micromark-extension-gfm-autolink-literal": "^2.0.0",
    "micromark-extension-gfm-strikethrough": "^2.0.0",
    "micromark-extension-gfm-table": "^2.0.0",
    "micromark-extension-mdxjs": "^3.0.0",
    "minimatch": "^9.0.3",
    "node-diff3": "^3.2.1",
    "prosemirror-commands": "^1.5.1",
    "prosemirror-history": "^1.3.0",
    "prosemirror-keymap": "^1.2.1",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.2",
    "prosemirror-tables": "^1.3.4",
    "prosemirror-transform": "^1.7.1",
    "prosemirror-view": "^1.30.2",
    "scroll-into-view-if-needed": "^3.0.3",
    "slate": "^0.91.4",
    "slate-history": "^0.86.0",
    "slate-react": "^0.91.9",
    "superstruct": "^1.0.4",
    "unist-util-visit": "^5.0.0",
    "urql": "^4.1.0",
    "y-prosemirror": "^1.2.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.2.5",
    "@iconify/utils": "^3.1.4",
    "@internationalized/string-compiler": "^3.2.6",
    "@jest/expect": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/user-event": "^14.6.1",
    "@ts-gql/compiler": "^0.16.7",
    "@ts-gql/eslint-plugin": "^0.9.1",
    "@ts-gql/next": "^17.0.1",
    "@types/is-hotkey": "^0.1.7",
    "@types/js-yaml": "^4.0.5",
    "@types/mdast": "^4.0.3",
    "@types/node": "25.0.3",
    "@types/prismjs": "^1.26.0",
    "@types/react-dom": "^19.0.3",
    "@types/signal-exit": "^3.0.1",
    "@vitest/pretty-format": "^3.0.5",
    "eslint": "^8.18.0",
    "jest-diff": "^29.0.1",
    "mkdist": "^2.4.1",
    "outdent": "^0.8.0",
    "prismjs": "^1.29.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-element-to-jsx-string": "^15.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "signal-exit": "^3.0.7",
    "slate-hyperscript": "^0.77.0",
    "tsx": "^4.8.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "ts-gql": {
    "schema": "./github.graphql",
    "mode": "no-transform",
    "addTypename": false,
    "scalars": {
      "GitObjectID": "string"
    }
  },
  "imports": {
    "#react-cache-in-react-server": {
      "react-server": "./dist/reader/react-server-cache.js",
      "default": "./dist/reader/noop-cache.js"
    },
    "#sha1": {
      "node": "./dist/sha1/node.js",
      "default": "./dist/sha1/webcrypto.js"
    },
    "#webcrypto": {
      "node": "./dist/api/webcrypto/node.js",
      "default": "./dist/api/webcrypto/default.js"
    },
    "#api-handler": {
      "node": "./dist/api/api-node.js",
      "default": "./dist/api/api-noop.js"
    },
    "#ui": {
      "node": "./dist/app/ui-empty.js",
      "worker": "./dist/app/ui-empty.js",
      "react-server": "./dist/app/ui-empty.js",
      "default": "./dist/app/ui.js"
    },
    "#field-ui/*": {
      "node": "./dist/form/fields/empty-field-ui.js",
      "worker": "./dist/form/fields/empty-field-ui.js",
      "react-server": "./dist/form/fields/empty-field-ui.js",
      "default": "./dist/form/fields/*/ui.js"
    },
    "#icons/*": "./dist/app/icons/*.js",
    "#component-block-primitives": {
      "node": "./dist/component-blocks/primitives/blank-for-react-server.js",
      "worker": "./dist/component-blocks/primitives/blank-for-react-server.js",
      "react-server": "./dist/component-blocks/primitives/blank-for-react-server.js",
      "default": "./dist/component-blocks/primitives/index.js"
    },
    "#markdoc": "./dist/markdoc.js",
    "#base64": "./dist/base64.js",
    "#react-compiler-runtime": {
      "react-server": "./dist/react-compiler-runtime-react-server.js",
      "default": "./dist/react-compiler-runtime.js"
    }
  }
}
