---
import Icon from "./Icon.astro";
import { getServices } from "../data/services";
import { getHomepage } from "../data/site";
import { parseHeadingLine } from "../lib/heading";

const services = await getServices();
const { brand, contact: contactInfo, socialLinks, footerNav, footer } =
  await getHomepage();

const { before: brandName, emphasis: brandHighlight } = parseHeadingLine(
  brand.name,
);
const phone = contactInfo.phoneDisplay.replace(/\D/g, "");

const nav = footerNav;

const contact = [
  { icon: "mail" as const, value: contactInfo.email },
  { icon: "phone" as const, value: contactInfo.phoneDisplay },
  { icon: "map-pin" as const, value: contactInfo.region },
];

const platformLabels: Record<string, string> = {
  facebook: "Facebook",
  x: "X (Twitter)",
  tiktok: "TikTok",
  zalo: "Zalo",
};

const socials = [
  ...socialLinks.map((s) => ({
    id: s.platform,
    label: platformLabels[s.platform] ?? s.platform,
    href: s.href,
  })),
  { id: "phone", label: "Điện thoại", href: `tel:${phone}` },
];

