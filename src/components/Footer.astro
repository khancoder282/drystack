---

<footer class="site-footer section--dark">
  <div class="container site-footer__grid reveal">
    <div class="footer-col footer-col--brand">
      <a href="/" class="brand">
        <span class="brand__mark">{brandName.charAt(0)}</span>
        <span class="brand__name">{brandName}<em>{brandHighlight}</em></span>
      </a>
      <p class="footer-col__desc">
        {footer.description}
      </p>
    </div>

    <div class="footer-col">
      <h4>Điều hướng</h4>
      <ul>
        {
          nav.map((n) => (
            <li>
              <a href={n.href}>{n.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h4>Dịch vụ</h4>
      <ul>
        {
          services.map((s) => (
            <li>
              <a href={`/dich-vu/${s.slug}`}>{s.title}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h4>Liên hệ</h4>
      <ul class="footer-col__contact">
        {
          contact.map((c) => (
            <li>
              <Icon name={c.icon} size={15} /> {c.value}
            </li>
          ))
        }
      </ul>

      <div class="footer-socials">
        {
          socials.map((s) => {
            const icon = socialIcons[s.id as keyof typeof socialIcons];
            const hasPaths = "paths" in icon;
            return (
              <a
                class="social-btn"
                href={s.href}
                aria-label={s.label}
                title={s.label}
              >
                <svg
                  viewBox={icon.viewBox}
                  width="18"
                  height="18"
                  aria-hidden="true"
                >
                  {s.id === "phone" ? (
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d={"path" in icon ? icon.path : ""}
                    />
                  ) : hasPaths ? (
                    <>
                      {(icon as any).paths.map((p: any) => (
                        <path
                          fill={p.fill ? p.fill : "currentColor"}
                          d={p.d}
                          fill-rule={p.fillRule}
                          clip-rule={p.clipRule}
                          opacity={p.opacity}
                        />
                      ))}
                    </>
                  ) : (
                    <path
                      fill="currentColor"
                      d={"path" in icon ? icon.path : ""}
                    />
                  )}
                </svg>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <div class="hairline"></div>
    <p class="site-footer__copy">
      {footer.copyright}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    padding-block: 4rem 2rem;
    border-top: 1px solid rgba(212, 175, 55, 0.15);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: 3rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
  }

  .brand__mark {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--primary-light), var(--secondary));
    color: var(--canvas-deep);
    font-weight: 800;
    font-size: 0.85rem;
  }

  .brand__name em {
    font-style: normal;
    color: var(--primary);
  }

  .footer-col__desc {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 32ch;
  }

  .footer-col h4 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    margin-bottom: 1.1rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-col a:hover {
    color: var(--primary-light);
  }

  .footer-col__contact li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-col__contact :global(.icon) {
    color: var(--primary-light);
    flex-shrink: 0;
  }

  .footer-socials {
    display: flex;
    gap: 0.7rem;
    margin-top: 1.6rem;
	overflow: visible;
  }

  .social-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(212, 175, 55, 0.35);
    color: var(--primary-light);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .social-btn:hover {
    transform: translateY(-3px);
    border-color: var(--primary);
    background: rgba(212, 175, 55, 0.12);
    color: var(--primary);
  }

  .site-footer__bottom .hairline {
    margin-bottom: 1.5rem;
  }

  .site-footer__copy {
    color: var(--text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  @media (max-width: 980px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
