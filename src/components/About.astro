---
import Icon from "./Icon.astro";
import Heading from "./Heading.astro";
import { getHomepage, getGioiThieuPage } from "../data/site";
import { parseHeadingLine } from "../lib/heading";

const [{ brand, about }, { hero, intro }] = await Promise.all([
  getHomepage(),
  getGioiThieuPage(),
]);
const { before: brandName, emphasis: brandHighlight } = parseHeadingLine(
  brand.name,
);
---

<section class="about section--light" id="about">
  <span class="section-kicker-word kicker-left">{about.eyebrow}</span>

  <div class="bg-layer">
    <div
      class="orb orb--gold"
      style="width:300px;height:300px;top:10%;right:-6%;opacity:0.18;"
      data-parallax="0.1"
    >
    </div>
  </div>

  <div class="container about__inner">
    <div class="about__card-wrap">
      <div class="about__card-glow"></div>
      <div class="about__card reveal reveal-left">
        <p class="eyebrow">{about.cardEyebrow}</p>
        <h3>{brandName}<em>{brandHighlight}</em></h3>
        <p class="about__card-desc">
          {hero.lede}
        </p>
        <div class="hairline"></div>
        <p class="about__card-status">
          <Icon name="circle-dot" size={12} /> {brand.availabilityStatus}
        </p>
      </div>
    </div>

    <div
      class="about__content reveal reveal-right"
      style="--reveal-delay: 160ms;"
    >
      <p class="eyebrow">{about.eyebrow}</p>
      <h2 class="section-title">
        <Heading text={about.heading} />
      </h2>
      <p
        class="section-lede"
        style="max-width:56ch; margin-block: 1.25rem 1.5rem;"
      >
        {intro.lede}
      </p>
      <ul class="about__points">
        {
          about.points.map((p) => (
            <li>
              <span class="check">
                <Icon name="check" size={13} />
              </span>
              {p}
            </li>
          ))
        }
      </ul>

      <a href="/gioi-thieu" class="btn btn-ghost about__more"
        >Xem chi tiết <Icon name="arrow-right" size={16} /></a
      >
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    z-index: 1;
    padding-block: 6rem;
    border-radius: 32px 32px 0 0;
    box-shadow: 0 -40px 60px -20px rgba(0, 0, 0, 0.35);
  }

  .about__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .about__card-wrap {
    position: relative;
  }

  .about__card {
    position: relative;
    background: var(--surface-light-card);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: 0 30px 60px -20px rgba(28, 26, 22, 0.25);
    border: 1px solid rgba(161, 127, 32, 0.15);
  }

  .about__card-glow {
    position: absolute;
    top: -18px;
    left: -18px;
    width: 70px;
    height: 70px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--primary-light), var(--secondary));
    opacity: 0.6;
  }

  .about__card h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    margin-block: 0.4rem 0.6rem;
  }

  .about__card h3 em {
    font-style: normal;
    color: var(--secondary);
  }

  .about__card-desc {
    color: var(--text-dark-muted);
    margin-bottom: 1.25rem;
  }

  .about__card-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--secondary);
    font-weight: 600;
  }

  .about__points {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .about__points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 500;
  }

  .about__more {
    margin-top: 2rem;
  }

  .check {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--primary-light);
    color: var(--canvas-deep);
    font-size: 0.75rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  @media (max-width: 860px) {
    .about__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
