---
import { createReader } from "@drystack/core/reader";
import config from "../../../drystack.config";

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), config);
  const posts = await reader.collections.posts.all({ resolveLinkedFiles: true });
  return posts
    .filter(({ entry }) => entry.publish)
    .map(({ slug, entry }) => ({ params: { slug }, props: { entry } }));
}

const { entry: post } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{post.title}</title>
    {post.description && <meta name="description" content={post.description} />}
  </head>
  <body>
    <main>
      <p><a href="/">← Back to home</a></p>
      <h1>{post.title}</h1>
      {post.description && <p>{post.description}</p>}
      {post.cover && (
        <img style="width: 300px;" src={post.cover.startsWith("/") ? post.cover : `/${post.cover}`} alt="" />
      )}
      {post.body && <Fragment set:html={post.body} />}
    </main>
  </body>
</html>
