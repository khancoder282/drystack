---
import Main from "../../layout/main.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import JsonLd from "../../components/JsonLd.astro";
import { getServices } from "../../data/services";
import { getHomepage } from "../../data/site";
import { parseHeadingLine } from "../../lib/heading";

export async function getStaticPaths() {
	const services = await getServices();
	return services.map((s) => ({
		params: { slug: s.slug },
	}));
}

// Fetched fresh by slug (rather than trusting the getStaticPaths props)
// so edits show up immediately in `astro dev` without a server restart -
// Astro only recomputes getStaticPaths props once per dev-server lifetime.
const services = await getServices();
const service = services.find((s) => s.slug === Astro.params.slug);
if (!service) {
	return Astro.redirect("/dich-vu");
}

const { brand } = await getHomepage();
const { before: brandName, emphasis: brandHighlight } = parseHeadingLine(
	brand.name,
);
const siteName = `${brandName}${brandHighlight}`;

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	name: service.title,
	description: service.metaDescription || service.desc,
	provider: { "@type": "Organization", name: siteName },
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Trang chủ", item: new URL("/", Astro.site).toString() },
		{ "@type": "ListItem", position: 2, name: "Dịch vụ", item: new URL("/dich-vu", Astro.site).toString() },
		{ "@type": "ListItem", position: 3, name: service.title, item: new URL(`/dich-vu/${service.slug}`, Astro.site).toString() },
	],
};
---

<Main
	title={service.metaTitle || `${service.title} | ${siteName}`}
	description={service.metaDescription || service.desc}
	image={service.ogImage || undefined}
>
	<JsonLd schema={[serviceSchema, breadcrumbSchema]} />
	<Header />

	<section class="service-hero section--dark" id="top">
		<div class="bg-layer">
			<div class="orb orb--gold" style="width:380px;height:380px;top:-10%;left:-8%;" data-parallax="0.12"></div>
		</div>
		<div class="container service-hero__inner">
			<a href="/dich-vu" class="back-link reveal"><Icon name="arrow-left" size={16} /> Tất cả dịch vụ</a>
			<p class="eyebrow reveal">Dịch vụ</p>
			<h1 class="section-title reveal">{service.title}</h1>
			<p class="service-hero__price reveal">{service.price}</p>
		</div>
	</section>

	<section class="service-detail section--light">
		<div class="container service-detail__inner">
			<div class="service-detail__main reveal reveal-left">
				<p class="section-lede">{service.intro}</p>

				<h2 class="service-detail__heading">Lợi ích khi sử dụng dịch vụ</h2>
				<ul class="service-detail__benefits" data-stagger="70">
					{service.benefits.map((b: string) => (
						<li class="reveal"><span class="check"><Icon name="check" size={13} /></span>{b}</li>
					))}
				</ul>

				<h2 class="service-detail__heading">Quy trình thực hiện</h2>
				<div class="service-detail__process" data-stagger>
					{service.process.map((p: { step: string; desc: string }, i: number) => (
						<div class="process-step reveal">
							<span class="process-step__num">{i + 1}</span>
							<div>
								<h3>{p.step}</h3>
								<p>{p.desc}</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<aside class="service-detail__aside reveal reveal-right">
				<div class="aside-card">
					<p class="eyebrow">Bao gồm</p>
					<div class="aside-card__tags">
						{service.tags.map((t: string) => <span>{t}</span>)}
					</div>
					<div class="hairline"></div>
					<p class="aside-card__price">{service.price}</p>
					<a href="/#contact" class="btn btn-primary">Liên hệ tư vấn <Icon name="arrow-right" size={16} /></a>
				</div>
			</aside>
		</div>
	</section>

	<Footer />
</Main>

<style>
	.service-hero {
		padding-block: 9rem 5rem;
	}

	.service-hero__inner {
		position: relative;
		z-index: 1;
	}

	.back-link {
		display: flex;
		width: fit-content;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}

	.back-link:hover {
		color: var(--primary-light);
	}

	.service-hero__price {
		margin-top: 0.75rem;
		color: var(--primary-light);
		font-weight: 700;
		font-size: 1.1rem;
	}

	.service-detail {
		padding-block: 5rem 6rem;
	}

	.service-detail__inner {
		display: grid;
		grid-template-columns: 1.6fr 1fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.service-detail__heading {
		font-family: var(--font-display);
		font-size: 1.5rem;
		margin-block: 2.5rem 1.25rem;
	}

	.service-detail__benefits {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.service-detail__benefits li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 500;
	}

	.check {
		display: grid;
		place-items: center;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--primary-light);
		color: var(--canvas-deep);
		flex-shrink: 0;
	}

	.service-detail__process {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.process-step {
		display: flex;
		gap: 1rem;
	}

	.process-step__num {
		display: grid;
		place-items: center;
		flex-shrink: 0;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--surface-light-card);
		border: 1px solid rgba(161, 127, 32, 0.3);
		color: var(--secondary);
		font-family: var(--font-display);
		font-weight: 800;
	}

	.process-step h3 {
		font-family: var(--font-display);
		font-size: 1.05rem;
		margin-bottom: 0.35rem;
	}

	.process-step p {
		color: var(--text-dark-muted);
		font-size: 0.92rem;
	}

	.aside-card {
		position: sticky;
		top: 7rem;
		background: var(--surface-light-card);
		border-radius: var(--radius-lg);
		padding: 1.75rem;
		box-shadow: 0 30px 60px -20px rgba(28, 26, 22, 0.2);
		border: 1px solid rgba(161, 127, 32, 0.15);
	}

	.aside-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-block: 1rem 1.25rem;
	}

	.aside-card__tags span {
		font-size: 0.72rem;
		color: var(--text-dark-muted);
		background: rgba(161, 127, 32, 0.08);
		border: 1px solid rgba(161, 127, 32, 0.15);
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
	}

	.aside-card .hairline {
		margin-block: 1.25rem;
	}

	.aside-card__price {
		font-weight: 700;
		font-size: 1.15rem;
		color: var(--secondary);
		margin-bottom: 1.25rem;
	}

	.aside-card .btn {
		width: 100%;
		justify-content: center;
	}

	@media (max-width: 860px) {
		.service-detail__inner {
			grid-template-columns: 1fr;
		}

		.aside-card {
			position: static;
		}
	}
</style>
